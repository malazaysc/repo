# Copy to .env and adjust. docker-compose reads .env automatically.

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (matches docker-compose db service)
POSTGRES_DB=repo
POSTGRES_USER=repo
POSTGRES_PASSWORD=repo
DATABASE_URL=postgres://repo:repo@db:5432/repo

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# YouTube transcript languages (priority order, comma-separated). Falls back to
# any available transcript in its own language if none match.
YOUTUBE_TRANSCRIPT_LANGUAGES=en,es

# X / Twitter (authenticated-browser scraping via Playwright).
# 1) Set INSTALL_BROWSERS=1 and rebuild the worker image.
# 2) Capture a session: uv run python manage.py capture_x_session
# 3) Set X_PARSER_ENABLED=1.
INSTALL_BROWSERS=0
X_PARSER_ENABLED=0
X_HEADLESS=1
# X_STORAGE_STATE_PATH=/app/secrets/x_storage_state.json

# AI summaries (Claude). Leave blank to disable AI; notes still ingest.
ANTHROPIC_API_KEY=
AI_SUMMARY_ENABLED=0
AI_SUMMARY_MODEL=claude-haiku-4-5-20251001
